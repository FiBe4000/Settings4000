export GDK_BACKEND=wayland,x11
#export GTK_THEME=Nordic-bluish-accent
# Cursor theme/size: canonical value; keep in sync with config/hypr/hyprland.conf
export XCURSOR_THEME=Nordic-cursors
export XCURSOR_SIZE=16
export QT_QPA_PLATFORM="wayland;xcb"
export QT_QPA_PLATFORMTHEME=gtk3
export QT_AUTO_SCREEN_SCALE_FACTOR=1

# Electron apps default to XWayland, which gets bitmap-upscaled on the
# fractional-scale laptop display -> blurry fonts after undocking. 'auto' makes
# Electron use native Wayland when available (proper per-monitor scaling),
# falling back to X11 otherwise.
export ELECTRON_OZONE_PLATFORM_HINT=auto
