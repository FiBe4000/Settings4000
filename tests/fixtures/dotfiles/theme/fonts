# Font settings for the theme pipeline.
#
# Read by scripts/generate-colors, which templates these into per-target
# generated font partials (config/kitty/fonts.conf, config/eww/_fonts.scss,
# config/rofi/fonts.rasi).
#
# Plain key=value lines; blank lines and lines starting with # are ignored.

# Single "font" knob: set mono_font to apply ONE family to all three targets at
# once. Leave it blank to fall back to the per-target *_font values below.
mono_font=

# Per-target monospace family fallbacks (used only when mono_font is blank).
kitty_font=FiraCodeNFM-Med
eww_font=DejaVuSansM Nerd Font Mono
rofi_font=DejaVuSans Mono

# Per-target font sizes. Kept independent because each target uses a different
# unit scale (kitty points, eww pixels, rofi points).
kitty_font_size=10
eww_font_size=14
rofi_font_size=20
